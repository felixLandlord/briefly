# ==============================================================================
# 🔴 REQUIRED CONFIGURATION
# The app will fail to perform research or generate briefs without these.
# ==============================================================================

# MiniMax - Required for the web-search subagent (MCP)
MINIMAX_API_KEY=your_minimax_api_key_here

# LLM Providers - You need at least the key for the model you intend to use.
# The orchestrator defaults to MiniMax-2.7 (using the MiniMax API key above).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
INCEPTION_API_KEY=
TAVILY_API_KEY=

# ==============================================================================
# 🟢 OPTIONAL CONFIGURATION
# Defaults are provided in app/core/config.py
# ==============================================================================

# App Environment & Logging
APP_ENV=development
LOG_LEVEL=INFO
OUTPUT_DIR=outputs

# Default Models (Options: claude-sonnet-4-5, gpt-5, MiniMax-2.7, etc.)
DEFAULT_ORCHESTRATOR_MODEL=MiniMax-2.7
DEFAULT_RESEARCHER_MODEL=MiniMax-2.7
DEFAULT_WRITER_MODEL=MiniMax-2.7

# Server & Network
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Provider Hosts (Change only if using proxies or custom endpoints)
MINIMAX_API_HOST=https://api.minimax.io
INCEPTION_API_HOST=https://api.inceptionlabs.ai/v1

# LangSmith Tracing
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=briefly
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
